msgid "Windows username"
msgstr "Nombre de usuario de Windows"

msgid "Windows password"
msgstr "Contraseña de Windows"

msgid "A Windows username and password are required to approve or reject."
msgstr "Se requieren un nombre de usuario y una contraseña de Windows para aprobar o rechazar."

msgid "The approval requester cannot approve or reject their own request — a second person is required."
msgstr "El solicitante de la aprobación no puede aprobar ni rechazar su propia solicitud — se requiere una segunda persona."

msgid "Windows user \"%1$s\" does not match the signed-in GLPI user \"%2$s\"."
msgstr "El usuario de Windows «%1$s» no coincide con el usuario GLPI conectado «%2$s»."

msgid "LDAP server is not configured (Setup > General > LDAP Re-auth)."
msgstr "El servidor LDAP no está configurado (Configuración > General > LDAP Re-auth)."

msgid "Invalid LDAP server URI: %s"
msgstr "URI del servidor LDAP no válida: %s"

msgid "LDAP authentication failed for \"%1$s\". Error: %2$s"
msgstr "Error de autenticación LDAP para «%1$s». Error: %2$s"

msgid "LDAP re-authentication OK — approved as \"%s\""
msgstr "Reautenticación LDAP correcta — aprobado como «%s»"

msgid "LDAP re-authentication OK — rejected as \"%s\""
msgstr "Reautenticación LDAP correcta — rechazado como «%s»"

msgid "LDAP Re-auth on Approval"
msgstr "Reautenticación LDAP en la aprobación"

msgid "LDAP server URI"
msgstr "URI del servidor LDAP"

msgid "Active Directory UPN suffix"
msgstr "Sufijo UPN de Active Directory"

msgid "Optional. e.g. example.com → user@example.com"
msgstr "Opcional. P. ej. example.com → user@example.com"

msgid "Active Directory NetBIOS domain"
msgstr "Dominio NetBIOS de Active Directory"

msgid "Optional. e.g. EXAMPLE → EXAMPLE\\user"
msgstr "Opcional. P. ej. EXAMPLE → EXAMPLE\\user"

msgid "Verify the LDAPS server certificate"
msgstr "Verificar el certificado del servidor LDAPS"

msgid "Turn off only for an internal CA the GLPI host does not trust."
msgstr "Desactivar solo para una CA interna en la que el host GLPI no confía."
