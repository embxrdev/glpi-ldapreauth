msgid "Windows username"
msgstr "Nom d'utilisateur Windows"

msgid "Windows password"
msgstr "Mot de passe Windows"

msgid "A Windows username and password are required to approve or reject."
msgstr "Un nom d'utilisateur et un mot de passe Windows sont requis pour valider ou refuser."

msgid "The approval requester cannot approve or reject their own request — a second person is required."
msgstr "Le demandeur de la validation ne peut pas valider ou refuser sa propre demande — une seconde personne est requise."

msgid "Windows user \"%1$s\" does not match the signed-in GLPI user \"%2$s\"."
msgstr "L'utilisateur Windows « %1$s » ne correspond pas à l'utilisateur GLPI connecté « %2$s »."

msgid "LDAP server is not configured (Setup > General > LDAP Re-auth)."
msgstr "Le serveur LDAP n'est pas configuré (Configuration > Générale > LDAP Re-auth)."

msgid "Invalid LDAP server URI: %s"
msgstr "URI du serveur LDAP invalide : %s"

msgid "StartTLS failed: %s"
msgstr "Échec de StartTLS : %s"

msgid "LDAP authentication failed for \"%1$s\". Error: %2$s"
msgstr "Échec de l'authentification LDAP pour « %1$s ». Erreur : %2$s"

msgid "LDAP re-authentication OK — approved as \"%s\""
msgstr "Ré-authentification LDAP réussie — validé en tant que « %s »"

msgid "LDAP re-authentication OK — rejected as \"%s\""
msgstr "Ré-authentification LDAP réussie — refusé en tant que « %s »"

msgid "LDAP Re-auth on Approval"
msgstr "Ré-authentification LDAP à la validation"

msgid "Step 1 — Connection"
msgstr "Étape 1 — Connexion"

msgid "Select the protocol and the directory server. Keep certificate verification enabled whenever possible."
msgstr "Sélectionnez le protocole et le serveur d'annuaire. Laissez la vérification du certificat activée autant que possible."

msgid "Protocol"
msgstr "Protocole"

msgid "ldaps:// (recommended) encrypts the connection. Combine plain ldap:// with StartTLS."
msgstr "ldaps:// (recommandé) chiffre la connexion. Combiner ldap:// avec StartTLS."

msgid "LDAP server"
msgstr "Serveur LDAP"

msgid "Host name, e.g. dc01.example.com. A full URI such as ldaps://host:636 also works and overrides the protocol."
msgstr "Nom d'hôte, ex. : dc01.example.com. Une URI complète comme ldaps://host:636 fonctionne aussi et prime sur le protocole."

msgid "Use StartTLS"
msgstr "Utiliser StartTLS"

msgid "Upgrades a plain ldap:// connection to TLS before binding. Do not use with ldaps:// URIs."
msgstr "Passe une connexion ldap:// en TLS avant la connexion. À ne pas utiliser avec les URI ldaps://."

msgid "Verify the LDAPS server certificate"
msgstr "Vérifier le certificat du serveur LDAPS"

msgid "Turn off only for an internal CA the GLPI host does not trust."
msgstr "À désactiver uniquement pour une CA interne non approuvée par l'hôte GLPI."

msgid "Step 2 — Active Directory (direct bind)"
msgstr "Étape 2 — Active Directory (bind direct)"

msgid "Only for Active Directory: short logins are expanded to user@domain and DOMAIN\\user. Skip this step for other directories."
msgstr "Uniquement pour Active Directory : les identifiants courts sont étendus en user@domain et DOMAIN\\user. Ignorez cette étape pour les autres annuaires."

msgid "Active Directory UPN suffix"
msgstr "Suffixe UPN Active Directory"

msgid "Optional. e.g. example.com → user@example.com"
msgstr "Facultatif. Ex. : example.com → user@example.com"

msgid "Active Directory NetBIOS domain"
msgstr "Domaine NetBIOS Active Directory"

msgid "Optional. e.g. EXAMPLE → EXAMPLE\\user"
msgstr "Facultatif. Ex. : EXAMPLE → EXAMPLE\\user"

msgid "Step 3 — Other directories (search & bind)"
msgstr "Étape 3 — Autres annuaires (search & bind)"

msgid "Only for directories such as OpenLDAP where a short login cannot bind directly: the plugin finds the user below the Base DN and then binds with the found DN."
msgstr "Uniquement pour les annuaires comme OpenLDAP où un identifiant court ne peut pas se connecter directement : le plugin recherche l'utilisateur sous le DN de base puis se connecte avec le DN trouvé."

msgid "Base DN"
msgstr "DN de base"

msgid "Optional. Enables search & bind for directories such as OpenLDAP. e.g. dc=example,dc=com"
msgstr "Facultatif. Active la recherche puis connexion (search & bind) pour les annuaires comme OpenLDAP. Ex. : dc=example,dc=com"

msgid "Login attribute"
msgstr "Attribut de connexion"

msgid "Attribute compared with the entered username. e.g. uid or sAMAccountName"
msgstr "Attribut comparé au nom d'utilisateur saisi. Ex. : uid ou sAMAccountName"

msgid "Search user DN"
msgstr "DN de l'utilisateur de recherche"

msgid "Optional. Account used to look up the user DN. Leave empty for an anonymous search."
msgstr "Facultatif. Compte utilisé pour rechercher le DN de l'utilisateur. Laisser vide pour une recherche anonyme."

msgid "Search user password"
msgstr "Mot de passe de l'utilisateur de recherche"

msgid "This plugin requires the PHP LDAP extension."
msgstr "Ce plugin nécessite l'extension PHP LDAP."

msgid "Complete Step 1 first, then fill in either Step 2 (Active Directory) or Step 3 (other directories such as OpenLDAP) — one of the two is enough. Only the server itself is strictly required."
msgstr "Complétez d'abord l'étape 1, puis renseignez soit l'étape 2 (Active Directory), soit l'étape 3 (autres annuaires comme OpenLDAP) — l'une des deux suffit. Seul le serveur lui-même est strictement requis."

msgid "Optional. Only needed together with a search user DN."
msgstr "Facultatif. Nécessaire uniquement avec un DN d'utilisateur de recherche."

msgid "LDAP authentication failed for \"%s\": wrong username or password."
msgstr "Échec de l'authentification LDAP pour « %s » : nom d'utilisateur ou mot de passe incorrect."

msgid "Cannot reach the LDAP server. Check the protocol (ldaps:// vs ldap://), the server name and the firewall."
msgstr "Impossible de joindre le serveur LDAP. Vérifiez le protocole (ldaps:// ou ldap://), le nom du serveur et le pare-feu."
