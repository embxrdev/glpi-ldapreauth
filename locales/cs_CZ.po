msgid "Windows username"
msgstr "Uživatelské jméno Windows"

msgid "Windows password"
msgstr "Heslo Windows"

msgid "A Windows username and password are required to approve or reject."
msgstr "Ke schválení nebo zamítnutí jsou vyžadovány uživatelské jméno a heslo Windows."

msgid "The approval requester cannot approve or reject their own request — a second person is required."
msgstr "Žadatel o schválení nemůže svou vlastní žádost schválit ani zamítnout — je vyžadována druhá osoba."

msgid "Windows user \"%1$s\" does not match the signed-in GLPI user \"%2$s\"."
msgstr "Uživatel Windows „%1$s“ neodpovídá přihlášenému uživateli GLPI „%2$s“."

msgid "LDAP server is not configured (Setup > General > LDAP Re-auth)."
msgstr "LDAP server není nakonfigurován (Nastavení > Obecné > LDAP Re-auth)."

msgid "Invalid LDAP server URI: %s"
msgstr "Neplatné URI LDAP serveru: %s"

msgid "StartTLS failed: %s"
msgstr "StartTLS se nezdařilo: %s"

msgid "LDAP authentication failed for \"%1$s\". Error: %2$s"
msgstr "Ověření LDAP se nezdařilo pro „%1$s“. Chyba: %2$s"

msgid "LDAP Re-auth on Approval"
msgstr "Opětovné ověření LDAP při schvalování"

msgid "Step 1 — Connection"
msgstr "Krok 1 — Připojení"

msgid "Select the protocol and the directory server. Keep certificate verification enabled whenever possible."
msgstr "Vyberte protokol a adresářový server. Ověřování certifikátu ponechte pokud možno zapnuté."

msgid "Protocol"
msgstr "Protokol"

msgid "ldaps:// (recommended) encrypts the connection. Combine plain ldap:// with StartTLS."
msgstr "ldaps:// (doporučeno) šifruje připojení. Běžné ldap:// kombinujte se StartTLS."

msgid "LDAP server"
msgstr "LDAP server"

msgid "Host name, e.g. dc01.example.com. A full URI such as ldaps://host:636 also works and overrides the protocol."
msgstr "Název hostitele, např. dc01.example.com. Funguje i úplné URI jako ldaps://host:636, které má přednost před protokolem."

msgid "Use StartTLS"
msgstr "Používat StartTLS"

msgid "Upgrades a plain ldap:// connection to TLS before binding. Do not use with ldaps:// URIs."
msgstr "Před bindem povýší běžné připojení ldap:// na TLS. Nepoužívejte s URI ldaps://."

msgid "Verify the LDAPS server certificate"
msgstr "Ověřovat certifikát serveru LDAPS"

msgid "Turn off only for an internal CA the GLPI host does not trust."
msgstr "Vypněte pouze pro interní CA, které hostitel GLPI nedůvěřuje."

msgid "Step 2 — Active Directory (direct bind)"
msgstr "Krok 2 — Active Directory (přímý bind)"

msgid "Only for Active Directory: short logins are expanded to user@domain and DOMAIN\\user. Skip this step for other directories."
msgstr "Pouze pro Active Directory: krátká přihlašovací jména se rozšíří na user@domain a DOMAIN\\user. U jiných adresářů tento krok přeskočte."

msgid "Active Directory UPN suffix"
msgstr "Přípona UPN Active Directory"

msgid "Optional. e.g. example.com → user@example.com"
msgstr "Volitelné. Např. example.com → user@example.com"

msgid "Active Directory NetBIOS domain"
msgstr "Doména NetBIOS Active Directory"

msgid "Optional. e.g. EXAMPLE → EXAMPLE\\user"
msgstr "Volitelné. Např. EXAMPLE → EXAMPLE\\user"

msgid "Step 3 — Other directories (search & bind)"
msgstr "Krok 3 — Jiné adresáře (vyhledání a bind)"

msgid "Only for directories such as OpenLDAP where a short login cannot bind directly: the plugin finds the user below the Base DN and then binds with the found DN."
msgstr "Pouze pro adresáře jako OpenLDAP, kde se krátké přihlašovací jméno nemůže bindovat přímo: zásuvný modul vyhledá uživatele pod základním DN a poté se binduje nalezeným DN."

msgid "Base DN"
msgstr "Základní DN"

msgid "Optional. Enables search & bind for directories such as OpenLDAP. e.g. dc=example,dc=com"
msgstr "Volitelné. Umožňuje vyhledání a bind pro adresáře jako OpenLDAP. Např. dc=example,dc=com"

msgid "Login attribute"
msgstr "Přihlašovací atribut"

msgid "Attribute compared with the entered username. e.g. uid or sAMAccountName"
msgstr "Atribut porovnávaný se zadaným uživatelským jménem. Např. uid nebo sAMAccountName"

msgid "Search user DN"
msgstr "DN vyhledávacího uživatele"

msgid "Optional. Account used to look up the user DN. Leave empty for an anonymous search."
msgstr "Volitelné. Účet použitý k vyhledání DN uživatele. Ponechte prázdné pro anonymní vyhledávání."

msgid "Search user password"
msgstr "Heslo vyhledávacího uživatele"

msgid "This plugin requires the PHP LDAP extension."
msgstr "Tento zásuvný modul vyžaduje rozšíření PHP LDAP."

msgid "Complete Step 1 first, then fill in either Step 2 (Active Directory) or Step 3 (other directories such as OpenLDAP) — one of the two is enough. Only the server itself is strictly required."
msgstr "Nejprve vyplňte krok 1, poté buď krok 2 (Active Directory), nebo krok 3 (jiné adresáře jako OpenLDAP) — stačí jeden z nich. Povinný je pouze samotný server."

msgid "Optional. Only needed together with a search user DN."
msgstr "Volitelné. Potřebné pouze společně s DN vyhledávacího uživatele."

msgid "LDAP authentication failed for \"%s\": wrong username or password."
msgstr "Ověření LDAP se nezdařilo pro „%s“: nesprávné uživatelské jméno nebo heslo."

msgid "Cannot reach the LDAP server. Check the protocol (ldaps:// vs ldap://), the server name and the firewall."
msgstr "LDAP server je nedostupný. Zkontrolujte protokol (ldaps:// vs. ldap://), název serveru a firewall."

msgid "Test connection"
msgstr "Otestovat připojení"

msgid "Save the settings first, then click to test the saved connection."
msgstr "Nejprve uložte nastavení a poté klikněte pro otestování uloženého připojení."

msgid "Connected to the LDAP server successfully."
msgstr "Připojení k LDAP serveru bylo úspěšné."

msgid "Connection established, but the search user sign-in failed: %s"
msgstr "Připojení navázáno, ale přihlášení vyhledávacího uživatele se nezdařilo: %s"

msgid "Connection test failed."
msgstr "Test připojení se nezdařil."

msgid "optional"
msgstr "volitelné"
