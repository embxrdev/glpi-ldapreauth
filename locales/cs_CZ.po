msgid "Windows username"
msgstr "Uživatelské jméno Windows"

msgid "Windows password"
msgstr "Heslo Windows"

msgid "A Windows username and password are required to approve or reject."
msgstr "Ke schválení nebo zamítnutí jsou vyžadovány uživatelské jméno a heslo Windows."

msgid "The approval requester cannot approve or reject their own request — a second person is required."
msgstr "Žadatel o schválení nemůže svou vlastní žádost schválit ani zamítnout — je vyžadována druhá osoba."

msgid "Windows user \"%1$s\" does not match the signed-in GLPI user \"%2$s\"."
msgstr "Uživatel Windows „%1$s“ neodpovídá přihlášenému uživateli GLPI „%2$s“."

msgid "LDAP server is not configured (Setup > General > LDAP Re-auth)."
msgstr "LDAP server není nakonfigurován (Nastavení > Obecné > LDAP Re-auth)."

msgid "Invalid LDAP server URI: %s"
msgstr "Neplatné URI LDAP serveru: %s"

msgid "LDAP authentication failed for \"%1$s\". Error: %2$s"
msgstr "Ověření LDAP se nezdařilo pro „%1$s“. Chyba: %2$s"

msgid "LDAP re-authentication OK — approved as \"%s\""
msgstr "Opětovné ověření LDAP proběhlo úspěšně — schváleno jako „%s“"

msgid "LDAP re-authentication OK — rejected as \"%s\""
msgstr "Opětovné ověření LDAP proběhlo úspěšně — zamítnuto jako „%s“"

msgid "LDAP Re-auth on Approval"
msgstr "Opětovné ověření LDAP při schvalování"

msgid "LDAP server URI"
msgstr "URI LDAP serveru"

msgid "Active Directory UPN suffix"
msgstr "Přípona UPN Active Directory"

msgid "Optional. e.g. example.com → user@example.com"
msgstr "Volitelné. Např. example.com → user@example.com"

msgid "Active Directory NetBIOS domain"
msgstr "Doména NetBIOS Active Directory"

msgid "Optional. e.g. EXAMPLE → EXAMPLE\\user"
msgstr "Volitelné. Např. EXAMPLE → EXAMPLE\\user"

msgid "Verify the LDAPS server certificate"
msgstr "Ověřovat certifikát serveru LDAPS"

msgid "Turn off only for an internal CA the GLPI host does not trust."
msgstr "Vypněte pouze pro interní CA, které hostitel GLPI nedůvěřuje."
