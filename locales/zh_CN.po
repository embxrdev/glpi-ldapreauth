msgid "Windows username"
msgstr "Windows 用户名"

msgid "Windows password"
msgstr "Windows 密码"

msgid "A Windows username and password are required to approve or reject."
msgstr "审批或拒绝需要提供 Windows 用户名和密码。"

msgid "The approval requester cannot approve or reject their own request — a second person is required."
msgstr "审批请求人不能审批或拒绝自己的请求 — 需要第二人处理。"

msgid "Windows user \"%1$s\" does not match the signed-in GLPI user \"%2$s\"."
msgstr "Windows 用户“%1$s”与已登录的 GLPI 用户“%2$s”不匹配。"

msgid "LDAP server is not configured (Setup > General > LDAP Re-auth)."
msgstr "未配置 LDAP 服务器（设置 > 常规 > LDAP Re-auth）。"

msgid "Invalid LDAP server URI: %s"
msgstr "无效的 LDAP 服务器 URI：%s"

msgid "StartTLS failed: %s"
msgstr "StartTLS 失败：%s"

msgid "LDAP authentication failed for \"%1$s\". Error: %2$s"
msgstr "用户“%1$s”的 LDAP 身份验证失败。错误：%2$s"

msgid "Approval authorised: \"%s\" confirmed their identity with their Windows password."
msgstr "审批已获授权：“%s”已使用 Windows 密码确认本人身份。"

msgid "Rejection authorised: \"%s\" confirmed their identity with their Windows password."
msgstr "拒绝已获授权：“%s”已使用 Windows 密码确认本人身份。"

msgid "LDAP Re-auth on Approval"
msgstr "审批时 LDAP 重新认证"

msgid "Step 1 — Connection"
msgstr "第 1 步 — 连接"

msgid "Select the protocol and the directory server. Keep certificate verification enabled whenever possible."
msgstr "选择协议和目录服务器。请尽可能保持证书验证开启。"

msgid "Protocol"
msgstr "协议"

msgid "ldaps:// (recommended) encrypts the connection. Combine plain ldap:// with StartTLS."
msgstr "ldaps://（推荐）加密连接。普通 ldap:// 请与 StartTLS 搭配使用。"

msgid "LDAP server"
msgstr "LDAP 服务器"

msgid "Host name, e.g. dc01.example.com. A full URI such as ldaps://host:636 also works and overrides the protocol."
msgstr "主机名，例如 dc01.example.com。也可填写完整 URI（如 ldaps://host:636），此时将优先于协议设置。"

msgid "Use StartTLS"
msgstr "使用 StartTLS"

msgid "Upgrades a plain ldap:// connection to TLS before binding. Do not use with ldaps:// URIs."
msgstr "在绑定前将普通 ldap:// 连接升级为 TLS。请勿与 ldaps:// URI 同时使用。"

msgid "Verify the LDAPS server certificate"
msgstr "验证 LDAPS 服务器证书"

msgid "Turn off only for an internal CA the GLPI host does not trust."
msgstr "仅在 GLPI 主机不信任的内部 CA 时才关闭。"

msgid "Step 2 — Active Directory (direct bind)"
msgstr "第 2 步 — Active Directory（直接绑定）"

msgid "Only for Active Directory: short logins are expanded to user@domain and DOMAIN\\user. Skip this step for other directories."
msgstr "仅适用于 Active Directory：短登录名会扩展为 user@domain 和 DOMAIN\\user。其他目录请跳过此步骤。"

msgid "Active Directory UPN suffix"
msgstr "Active Directory UPN 后缀"

msgid "Optional. e.g. example.com → user@example.com"
msgstr "可选。例如 example.com → user@example.com"

msgid "Active Directory NetBIOS domain"
msgstr "Active Directory NetBIOS 域"

msgid "Optional. e.g. EXAMPLE → EXAMPLE\\user"
msgstr "可选。例如 EXAMPLE → EXAMPLE\\user"

msgid "Step 3 — Other directories (search & bind)"
msgstr "第 3 步 — 其他目录（先搜索后绑定）"

msgid "Only for directories such as OpenLDAP where a short login cannot bind directly: the plugin finds the user below the Base DN and then binds with the found DN."
msgstr "仅适用于 OpenLDAP 等短登录名无法直接绑定的目录：插件在基准 DN 下查找用户，然后使用找到的 DN 进行绑定。"

msgid "Base DN"
msgstr "基准 DN"

msgid "Optional. Enables search & bind for directories such as OpenLDAP. e.g. dc=example,dc=com"
msgstr "可选。为 OpenLDAP 等目录启用先搜索后绑定。例如 dc=example,dc=com"

msgid "Login attribute"
msgstr "登录属性"

msgid "Attribute compared with the entered username. e.g. uid or sAMAccountName"
msgstr "与输入的用户名进行匹配的属性。例如 uid 或 sAMAccountName"

msgid "Search user DN"
msgstr "搜索用户 DN"

msgid "Optional. Account used to look up the user DN. Leave empty for an anonymous search."
msgstr "可选。用于查找用户 DN 的帐户。留空则使用匿名搜索。"

msgid "Search user password"
msgstr "搜索用户密码"

msgid "This plugin requires the PHP LDAP extension."
msgstr "此插件需要 PHP 的 LDAP 扩展。"

msgid "Complete Step 1 first, then fill in either Step 2 (Active Directory) or Step 3 (other directories such as OpenLDAP) — one of the two is enough. Only the server itself is strictly required."
msgstr "请先完成第 1 步，然后填写第 2 步（Active Directory）或第 3 步（OpenLDAP 等其他目录）——两者填一个即可。严格必填的只有服务器本身。"

msgid "Optional. Only needed together with a search user DN."
msgstr "可选。仅在填写搜索用户 DN 时需要。"

msgid "LDAP authentication failed for \"%s\": wrong username or password."
msgstr "用户“%s”的 LDAP 身份验证失败：用户名或密码错误。"

msgid "Cannot reach the LDAP server. Check the protocol (ldaps:// vs ldap://), the server name and the firewall."
msgstr "无法连接 LDAP 服务器。请检查协议（ldaps:// 与 ldap://）、服务器名称和防火墙。"
