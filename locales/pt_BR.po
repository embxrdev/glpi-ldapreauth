msgid "Windows username"
msgstr "Nome de usuário do Windows"

msgid "Windows password"
msgstr "Senha do Windows"

msgid "A Windows username and password are required to approve or reject."
msgstr "Um nome de usuário e uma senha do Windows são necessários para aprovar ou recusar."

msgid "Windows user \"%1$s\" does not match the signed-in GLPI user \"%2$s\"."
msgstr "O usuário do Windows \"%1$s\" não corresponde ao usuário GLPI conectado \"%2$s\"."

msgid "LDAP server is not configured (Setup > General > LDAP Re-auth)."
msgstr "O servidor LDAP não está configurado (Configurar > Geral > LDAP Re-auth)."

msgid "Invalid LDAP server URI: %s"
msgstr "URI do servidor LDAP inválida: %s"

msgid "LDAP authentication failed for \"%1$s\". Error: %2$s"
msgstr "Falha na autenticação LDAP para \"%1$s\". Erro: %2$s"

msgid "LDAP re-authentication OK — approved as \"%s\""
msgstr "Reautenticação LDAP bem-sucedida — aprovado como \"%s\""

msgid "LDAP re-authentication OK — rejected as \"%s\""
msgstr "Reautenticação LDAP bem-sucedida — recusado como \"%s\""

msgid "LDAP Re-auth on Approval"
msgstr "Reautenticação LDAP na aprovação"

msgid "LDAP server URI"
msgstr "URI do servidor LDAP"

msgid "Active Directory UPN suffix"
msgstr "Sufixo UPN do Active Directory"

msgid "Optional. e.g. example.com → user@example.com"
msgstr "Opcional. Ex.: example.com → user@example.com"

msgid "Active Directory NetBIOS domain"
msgstr "Domínio NetBIOS do Active Directory"

msgid "Optional. e.g. EXAMPLE → EXAMPLE\\user"
msgstr "Opcional. Ex.: EXAMPLE → EXAMPLE\\user"

msgid "Require the LDAP user to match the signed-in GLPI approver"
msgstr "Exigir que o usuário LDAP corresponda ao aprovador GLPI conectado"

msgid "Verify the LDAPS server certificate"
msgstr "Verificar o certificado do servidor LDAPS"

msgid "Turn off only for an internal CA the GLPI host does not trust."
msgstr "Desative apenas para uma CA interna na qual o host GLPI não confia."
