msgid "Windows username"
msgstr "Имя пользователя Windows"

msgid "Windows password"
msgstr "Пароль Windows"

msgid "A Windows username and password are required to approve or reject."
msgstr "Для утверждения или отклонения требуются имя пользователя и пароль Windows."

msgid "The approval requester cannot approve or reject their own request — a second person is required."
msgstr "Запросивший утверждение не может утвердить или отклонить собственный запрос — требуется второй человек."

msgid "Windows user \"%1$s\" does not match the signed-in GLPI user \"%2$s\"."
msgstr "Пользователь Windows «%1$s» не совпадает с вошедшим пользователем GLPI «%2$s»."

msgid "LDAP server is not configured (Setup > General > LDAP Re-auth)."
msgstr "Сервер LDAP не настроен (Настройки > Общие > LDAP Re-auth)."

msgid "Invalid LDAP server URI: %s"
msgstr "Недопустимый URI сервера LDAP: %s"

msgid "LDAP authentication failed for \"%1$s\". Error: %2$s"
msgstr "Ошибка аутентификации LDAP для «%1$s». Ошибка: %2$s"

msgid "LDAP re-authentication OK — approved as \"%s\""
msgstr "Повторная аутентификация LDAP выполнена — утверждено как «%s»"

msgid "LDAP re-authentication OK — rejected as \"%s\""
msgstr "Повторная аутентификация LDAP выполнена — отклонено как «%s»"

msgid "LDAP Re-auth on Approval"
msgstr "Повторная аутентификация LDAP при утверждении"

msgid "LDAP server URI"
msgstr "URI сервера LDAP"

msgid "Active Directory UPN suffix"
msgstr "UPN-суффикс Active Directory"

msgid "Optional. e.g. example.com → user@example.com"
msgstr "Необязательно. Напр. example.com → user@example.com"

msgid "Active Directory NetBIOS domain"
msgstr "NetBIOS-домен Active Directory"

msgid "Optional. e.g. EXAMPLE → EXAMPLE\\user"
msgstr "Необязательно. Напр. EXAMPLE → EXAMPLE\\user"

msgid "Verify the LDAPS server certificate"
msgstr "Проверять сертификат сервера LDAPS"

msgid "Turn off only for an internal CA the GLPI host does not trust."
msgstr "Отключайте только для внутреннего ЦС, которому хост GLPI не доверяет."
